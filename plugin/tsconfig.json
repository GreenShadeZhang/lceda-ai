{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@jlceda/pro-api-types"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build"]
}
