# ============================================================
# .env.example — 本地开发环境变量模板
# 用法：cp .env.example .env，然后填入真实值
# 注意：.env 已加入 .gitignore，请勿将真实密钥提交到版本控制
# ============================================================

# === OpenAI / Azure OpenAI 配置 ===
# Azure OpenAI 终结点，格式：https://<resource>.openai.azure.com/
OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# API Key（Azure OpenAI 或 OpenAI 官方）
OPENAI_API_KEY=your-api-key-here

# 部署模型名称（Azure 使用 Deployment Name，OpenAI 使用模型 ID）
OPENAI_MODEL_NAME=gpt-4o
